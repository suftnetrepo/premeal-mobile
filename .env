# Your deployed premeal-app instance. For local dev with a physical
# device or simulator, "localhost" means the device itself, not your
# computer — use your computer's LAN IP instead, e.g.
# http://192.168.1.42:3000. Find it with `ipconfig getifaddr en0` (Mac)
# or `ipconfig` (Windows, look for IPv4 Address).
EXPO_PUBLIC_API_URL="https://premeal.onrender.com"

# Same Stripe TEST-mode publishable key as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# in premeal-app's .env — this is a public key, safe to ship in the app
# bundle, but it must match the same Stripe account/mode as the backend
# or SetupIntent confirmation will fail.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51Ttl3xRgE6Qwrcme0ujqpdyepQSNQkUgnGAiZUNXEH5epDHkt0zPYLPKPXDASf3S9yXV8LqqmBcjmSJ796cSWKTN00xTweoy5Q"
